        return JsonSupport.count(result);
    }

    private {{ model_name }} upsertInternal({{ dsl_name }}.UpsertArgs args) {
        List<{{ model_name }}> existing = findManyInternal(new {{ dsl_name }}.FindManyArgs().where(w -> w.raw(args.whereNode())).take(1));
        if (!existing.isEmpty()) {
            List<{{ model_name }}> updated = updateInternal(new {{ dsl_name }}.UpdateArgs().where(w -> w.raw(args.whereNode())).data(args.updateNode()));
            return updated.isEmpty() ? existing.get(0) : updated.get(0);
        }
        return createInternal(new {{ dsl_name }}.CreateInput(args.createNode()));
    }

    private List<JsonNode> groupByInternal({{ dsl_name }}.GroupByArgs args) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        request.set("args", args == null ? JsonSupport.object() : args.node());
        JsonNode result = rpc("query.groupBy", request);
        return JsonSupport.dataList(result, JsonNode::deepCopy);
