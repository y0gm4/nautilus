        request.put("protocolVersion", 1);
        request.put("sql", sql);
        request.set("params", JsonSupport.toJsonNode(params));
        JsonNode result = rpc("query.rawStmtQuery", request);
        return JsonSupport.dataList(result, JsonNode::deepCopy);
