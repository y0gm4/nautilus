    private List<{{ model_name }}> findManyInternal({{ dsl_name }}.FindManyArgs args) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        request.set("args", args == null ? JsonSupport.object() : args.node());
        if (args != null && args.chunkSize() != null) {
            request.put("chunkSize", args.chunkSize().intValue());
        }
        JsonNode result = rpc("query.findMany", request);
        return rows(result, {{ model_name }}::fromJsonNode);
    }

    private {{ model_name }} findFirstInternal({{ dsl_name }}.FindManyArgs args) {
        {{ dsl_name }}.FindManyArgs actual = args == null ? new {{ dsl_name }}.FindManyArgs() : args;
        actual.take(1);
        List<{{ model_name }}> rows = findManyInternal(actual);
        return rows.isEmpty() ? null : rows.get(0);
    }

    private {{ model_name }} createInternal({{ dsl_name }}.CreateInput data) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        request.set("data", data == null ? JsonSupport.object() : data.node());
        request.put("returnData", true);
        JsonNode result = rpc("query.create", request);
        JsonNode row = JsonSupport.firstDataRow(result);
        if (row == null || row.isNull()) {
            throw new NautilusException("create: engine returned no data");
        }
        return {{ model_name }}.fromJsonNode(row);
    }

    private List<{{ model_name }}> createManyInternal(List<{{ dsl_name }}.CreateInput> data) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        ArrayNode items = JsonSupport.array();
        for ({{ dsl_name }}.CreateInput item : data) {
            items.add(item.node());
        }
        request.set("data", items);
        request.put("returnData", true);
        JsonNode result = rpc("query.createMany", request);
        return rows(result, {{ model_name }}::fromJsonNode);
    }

    private List<{{ model_name }}> updateInternal({{ dsl_name }}.UpdateArgs args) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        request.set("filter", args == null ? JsonSupport.object() : args.whereNode());
        request.set("data", args == null ? JsonSupport.object() : args.dataNode());
        request.put("returnData", true);
        JsonNode result = rpc("query.update", request);
        return rows(result, {{ model_name }}::fromJsonNode);
    }

    private {{ model_name }} deleteInternal({{ dsl_name }}.DeleteArgs args) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        request.set("filter", args == null ? JsonSupport.object() : args.whereNode());
        request.put("returnData", true);
        JsonNode result = rpc("query.delete", request);
        JsonNode row = JsonSupport.firstDataRow(result);
        if (row == null || row.isNull()) {
            throw new NotFoundException("delete: no {{ model_name }} record found matching the given filter");
        }
        return {{ model_name }}.fromJsonNode(row);
    }

    private long deleteManyInternal({{ dsl_name }}.DeleteArgs args) {
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", 1);
        request.put("model", "{{ model_name }}");
        request.set("filter", args == null ? JsonSupport.object() : args.whereNode());
        request.put("returnData", false);
        JsonNode result = rpc("query.delete", request);
