    private ObjectNode buildFindManyRequest({{ dsl_name }}.FindManyArgs args) {
        {{ dsl_name }}.FindManyArgs actual = args == null ? new {{ dsl_name }}.FindManyArgs() : args;
        ObjectNode request = JsonSupport.object();
        request.put("protocolVersion", JsonSupport.PROTOCOL_VERSION);
        request.put("model", "{{ model_name }}");
        request.set("args", actual.node());
        if (actual.chunkSize() != null) {
            request.put("chunkSize", actual.chunkSize().intValue());
        }
        return request;
    }

    private void rejectSelectForModelResult({{ dsl_name }}.FindManyArgs args) {
        {{ dsl_name }}.FindManyArgs actual = args == null ? new {{ dsl_name }}.FindManyArgs() : args;
        if (actual.node().has("select")) {
            throw new IllegalArgumentException(
                "select returns partial rows and cannot be decoded as a full {{ model_name }} record; use findManySelect, findFirstSelect, or findUniqueSelect instead"
            );
        }
    }

    private void requireSelectForProjection({{ dsl_name }}.FindManyArgs args) {
        {{ dsl_name }}.FindManyArgs actual = args == null ? new {{ dsl_name }}.FindManyArgs() : args;
        if (!actual.node().has("select")) {
            throw new IllegalArgumentException(
                "select projection APIs require select(...); use findMany/findFirst/findUnique for full {{ model_name }} records"
            );
        }
    }

    private JsonNode rawProjectionRow(JsonNode row) {
        if (row == null || row.isNull()) {
            return null;
        }
        return row.deepCopy();
    }

