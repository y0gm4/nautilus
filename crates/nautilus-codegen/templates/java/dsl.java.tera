    public static final class UpdateArgs implements WireSerializable {
        private ObjectNode where = JsonSupport.object();
        private ObjectNode data = JsonSupport.object();

        public UpdateArgs where(Consumer<Where> spec) {
            Where builder = new Where();
            if (spec != null) {
                spec.accept(builder);
            }
            this.where = builder.node();
            return this;
        }

        public UpdateArgs data(Consumer<UpdateInput> spec) {
            UpdateInput builder = new UpdateInput();
            if (spec != null) {
                spec.accept(builder);
            }
            this.data = builder.node();
            return this;
        }

        public UpdateArgs data(JsonNode raw) {
            this.data = JsonSupport.objectNode(raw);
            return this;
        }

        public ObjectNode whereNode() {
            return this.where.deepCopy();
        }

        public ObjectNode dataNode() {
            return this.data.deepCopy();
        }

        @Override
        public JsonNode toJsonNode() {
            ObjectNode node = JsonSupport.object();
            node.set("where", whereNode());
            node.set("data", dataNode());
            return node;
        }
    }

    public static final class DeleteArgs implements WireSerializable {
