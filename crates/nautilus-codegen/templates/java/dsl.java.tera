    public static final class FindManyArgs implements WireSerializable {
        private final ObjectNode node = JsonSupport.object();
        private Integer chunkSize;

        public FindManyArgs where(Consumer<Where> spec) {
            Where where = new Where();
            if (spec != null) {
                spec.accept(where);
            }
            this.node.set("where", where.node());
            return this;
        }

        public FindManyArgs orderBy(Consumer<OrderBy> spec) {
            OrderBy orderBy = new OrderBy();
            if (spec != null) {
                spec.accept(orderBy);
            }
            this.node.set("orderBy", orderBy.node());
            return this;
        }

{% if vector_field_names | length > 0 %}
        public FindManyArgs nearest(Consumer<Nearest> spec) {
            Nearest nearest = new Nearest();
            if (spec != null) {
                spec.accept(nearest);
            }
            this.node.set("nearest", nearest.node());
            return this;
        }

{% endif %}

        public FindManyArgs take(int value) {
            this.node.put("take", value);
            return this;
        }

        public FindManyArgs skip(int value) {
            this.node.put("skip", value);
            return this;
        }

        public FindManyArgs select(Consumer<Select> spec) {
            Select select = new Select();
            if (spec != null) {
                spec.accept(select);
            }
            this.node.set("select", select.node());
            return this;
        }

        public FindManyArgs include(Consumer<Include> spec) {
            Include include = new Include();
            if (spec != null) {
                spec.accept(include);
            }
            this.node.set("include", include.node());
            return this;
        }

        public FindManyArgs cursor(String field, Object value) {
            ObjectNode cursor = this.node.has("cursor") && this.node.get("cursor").isObject() ? (ObjectNode) this.node.get("cursor") : JsonSupport.object();
            cursor.set(field, JsonSupport.toJsonNode(value));
            this.node.set("cursor", cursor);
            return this;
        }

        public FindManyArgs distinct(ScalarField... fields) {
            ArrayNode values = JsonSupport.array();
            for (ScalarField field : fields) {
                values.add(field.wireName());
            }
            this.node.set("distinct", values);
            return this;
        }

        public FindManyArgs chunkSize(int chunkSize) {
            this.chunkSize = chunkSize;
            return this;
        }

        public Integer chunkSize() {
            return this.chunkSize;
        }

{{ m::serializable_tail() }}
    }

