{%- import "_dsl_macros.tera" as m -%}
package {{ package_name }}.dsl;

{%- for import in imports %}
import {{ import }};
{%- endfor %}

public final class {{ name }} {
    private {{ name }}() {
    }

    public enum ScalarField {
{%- for field in scalar_fields %}
{%- if loop.last %}
        {{ field.variant_name }}("{{ field.name }}");
{%- else %}
        {{ field.variant_name }}("{{ field.name }}"),
{%- endif %}
{%- endfor %}

        private final String wireName;

        ScalarField(String wireName) {
            this.wireName = wireName;
        }

        public String wireName() {
            return this.wireName;
        }
    }

    public static final class Where implements WireSerializable {
        private final ObjectNode node;

        public Where() {
            this.node = JsonSupport.object();
        }

        public Where raw(JsonNode value) {
            if (value instanceof ObjectNode objectNode) {
                this.node.removeAll();
                this.node.setAll(objectNode.deepCopy());
            }
            return this;
        }

        public Where and(Consumer<Where> spec) {
            Where child = new Where();
            if (spec != null) {
                spec.accept(child);
            }
            Filters.and(this.node, child.node());
            return this;
        }

        public Where or(Consumer<Where> spec) {
            Where child = new Where();
            if (spec != null) {
                spec.accept(child);
            }
            Filters.or(this.node, child.node());
            return this;
        }

        public Where not(Consumer<Where> spec) {
            Where child = new Where();
            if (spec != null) {
                spec.accept(child);
            }
            Filters.not(this.node, child.node());
            return this;
        }

{%- for field in scalar_fields %}
        public Where {{ field.name }}({{ field.java_type }} value) {
            Filters.equals(this.node, "{{ field.db_name }}", value);
            return this;
        }

{%- for op in field.filter_ops %}
        public Where {{ field.name }}{{ op.suffix_pascal }}({{ op.java_type }} value) {
            Filters.operator(this.node, "{{ field.db_name }}", "{{ op.suffix }}", value);
            return this;
        }

{%- endfor %}
{%- endfor %}
{{ m::serializable_tail() }}
    }

    public static final class Select implements WireSerializable {
        private final ObjectNode node = JsonSupport.object();

{%- for field in scalar_fields %}
        public Select {{ field.name }}() {
            return {{ field.name }}(true);
        }

        public Select {{ field.name }}(boolean selected) {
            this.node.put("{{ field.name }}", selected);
            return this;
        }

{%- endfor %}
{{ m::serializable_tail() }}
    }

    public static final class Include implements WireSerializable {
        private final ObjectNode node = JsonSupport.object();

{%- for rel in relation_fields %}
        public Include {{ rel.name }}() {
            this.node.put("{{ rel.name }}", true);
            return this;
        }

        public Include {{ rel.name }}(Consumer<{{ rel.target_model }}Dsl.FindManyArgs> spec) {
            {{ rel.target_model }}Dsl.FindManyArgs args = new {{ rel.target_model }}Dsl.FindManyArgs();
            if (spec != null) {
                spec.accept(args);
            }
            this.node.set("{{ rel.name }}", args.node());
            return this;
        }

{%- endfor %}
{{ m::serializable_tail() }}
    }

    public static final class OrderBy implements WireSerializable {
        private final ObjectNode node = JsonSupport.object();

{%- for name in orderable_field_names %}
        public OrderBy {{ name }}(SortOrder order) {
            this.node.put("{{ name }}", order.wireValue());
            return this;
        }

{%- endfor %}
{{ m::serializable_tail() }}
    }

{% if vector_field_names | length > 0 %}
    public enum VectorMetric {
        L2("l2"),
        INNER_PRODUCT("innerProduct"),
        COSINE("cosine");

        private final String wireValue;

        VectorMetric(String wireValue) {
            this.wireValue = wireValue;
        }

        public String wireValue() {
            return this.wireValue;
        }
    }

    public static final class Nearest implements WireSerializable {
        private final ObjectNode node = JsonSupport.object();

{%- for name in vector_field_names %}
        public Nearest {{ name }}() {
            this.node.put("field", "{{ name }}");
            return this;
        }

{%- endfor %}
        public Nearest query(List<Float> value) {
            this.node.set("query", JsonSupport.toJsonNode(value));
            return this;
        }

        public Nearest metric(VectorMetric metric) {
            this.node.put("metric", metric.wireValue());
            return this;
        }

{{ m::serializable_tail() }}
    }

{% endif %}
    public static final class CreateInput implements WireSerializable {
        private final ObjectNode node;

        public CreateInput() {
            this.node = JsonSupport.object();
        }

        public CreateInput(JsonNode raw) {
            this.node = JsonSupport.objectNode(raw);
        }

{%- for field in create_fields %}
        public CreateInput {{ field.name }}({{ field.java_type }} value) {
            this.node.set("{{ field.db_name }}", JsonSupport.toJsonNode(value));
            return this;
        }

{%- endfor %}
{{ m::serializable_tail() }}
    }

