    public static final class GroupByArgs implements WireSerializable {
        private final ObjectNode node = JsonSupport.object();

        public GroupByArgs by(ScalarField... fields) {
            ArrayNode values = JsonSupport.array();
            for (ScalarField field : fields) {
                values.add(field.wireName());
            }
            this.node.set("by", values);
            return this;
        }

        public GroupByArgs where(Consumer<Where> spec) {
            Where builder = new Where();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("where", builder.node());
            return this;
        }

        public GroupByArgs having(JsonNode having) {
            this.node.set("having", JsonSupport.toJsonNode(having));
            return this;
        }

        public GroupByArgs take(int value) {
            this.node.put("take", value);
            return this;
        }

        public GroupByArgs skip(int value) {
            this.node.put("skip", value);
            return this;
        }

        public GroupByArgs count(Consumer<CountAggregate> spec) {
            CountAggregate builder = new CountAggregate();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("count", builder.node());
            return this;
        }

        public GroupByArgs avg(Consumer<AvgAggregate> spec) {
            AvgAggregate builder = new AvgAggregate();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("avg", builder.node());
            return this;
        }

        public GroupByArgs sum(Consumer<SumAggregate> spec) {
            SumAggregate builder = new SumAggregate();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("sum", builder.node());
            return this;
        }

        public GroupByArgs min(Consumer<MinAggregate> spec) {
            MinAggregate builder = new MinAggregate();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("min", builder.node());
            return this;
        }

        public GroupByArgs max(Consumer<MaxAggregate> spec) {
            MaxAggregate builder = new MaxAggregate();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("max", builder.node());
            return this;
        }

        public GroupByArgs orderBy(Consumer<OrderBy> spec) {
            OrderBy builder = new OrderBy();
            if (spec != null) {
                spec.accept(builder);
            }
            this.node.set("orderBy", builder.node());
            return this;
        }

{{ m::serializable_tail() }}
