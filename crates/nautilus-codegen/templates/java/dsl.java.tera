            }
            this.where = builder.node();
            return this;
        }

        public ObjectNode whereNode() {
            return this.where.deepCopy();
        }

        @Override
        public JsonNode toJsonNode() {
            return whereNode();
        }
    }

    public static final class UpsertArgs implements WireSerializable {
        private ObjectNode where = JsonSupport.object();
        private ObjectNode create = JsonSupport.object();
        private ObjectNode update = JsonSupport.object();
        private ObjectNode include = JsonSupport.object();

        public UpsertArgs where(Consumer<Where> spec) {
            Where builder = new Where();
            if (spec != null) {
                spec.accept(builder);
            }
            this.where = builder.node();
            return this;
        }

        public UpsertArgs create(Consumer<CreateInput> spec) {
            CreateInput builder = new CreateInput();
            if (spec != null) {
                spec.accept(builder);
            }
            this.create = builder.node();
            return this;
        }

        public UpsertArgs update(Consumer<UpdateInput> spec) {
            UpdateInput builder = new UpdateInput();
            if (spec != null) {
                spec.accept(builder);
            }
            this.update = builder.node();
            return this;
        }

        public UpsertArgs include(Consumer<Include> spec) {
            Include builder = new Include();
            if (spec != null) {
                spec.accept(builder);
            }
            this.include = builder.node();
            return this;
        }

        public ObjectNode whereNode() {
            return this.where.deepCopy();
        }

        public ObjectNode createNode() {
            return this.create.deepCopy();
        }

        public ObjectNode updateNode() {
            return this.update.deepCopy();
        }

        public ObjectNode includeNode() {
            return this.include.deepCopy();
        }

        @Override
        public JsonNode toJsonNode() {
            ObjectNode node = JsonSupport.object();
            node.set("where", whereNode());
            node.set("create", createNode());
            node.set("update", updateNode());
            node.set("include", includeNode());
            return node;
        }
    }

